{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run example (debug)",
      "request": "launch",
      "type": "dart",
      "program": "${workspaceFolder}/example/lib/main.dart"
    },
    {
      "name": "Run example (release)",
      "request": "launch",
      "type": "dart",
      "program": "${workspaceFolder}/example/lib/main.dart",
      "args": [
        "--release"
      ]
    },
    {
      "name": "Run integration test",
      "request": "launch",
      "type": "dart",
      "program": "${workspaceFolder}/example/integration_test/main_test.dart"
    }
  ]
}